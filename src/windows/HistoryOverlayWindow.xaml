<Window
    x:Class="LiveCaptionsTranslator.HistoryOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="History Overlay"
    Width="550" Height="400"
    MinWidth="300" MinHeight="200"
    AllowsTransparency="True" Background="Transparent"
    WindowStyle="None" Topmost="True" ShowInTaskbar="False"
    Top="100" Left="100"
    MouseEnter="Window_MouseEnter"
    MouseLeave="Window_MouseLeave">

    <Window.Resources>
        <Style x:Key="TransparentThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Opacity" Value="0" />
        </Style>
    </Window.Resources>

    <Grid Background="Transparent">
        <Border x:Name="BorderBackground" Margin="5" CornerRadius="8">
            <Border.Background>
                <SolidColorBrush Color="Black" Opacity="{Binding Value, ElementName=OpacitySlider}"/>
            </Border.Background>
        </Border>

        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" MouseLeftButtonDown="DragHandle_MouseLeftButtonDown" Background="Transparent" Cursor="SizeAll">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Slider x:Name="OpacitySlider" Grid.Column="1" Width="100" VerticalAlignment="Center" Margin="10,0" 
                        Minimum="0.0" Maximum="1.0" Value="0.85" ToolTip="Adjust Background Opacity" Cursor="Hand" />

                <ui:Button Grid.Column="2" Margin="5" Appearance="Transparent" 
                           Foreground="White"
                           Icon="{ui:SymbolIcon Dismiss24, Filled=False}" Click="CloseButton_Click" ToolTip="Close History"/>
            </Grid>

            <ScrollViewer x:Name="HistoryScrollViewer" Grid.Row="1" Margin="10,0,10,10" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="HistoryList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10" Padding="8" Background="Transparent" CornerRadius="5">
                                <StackPanel>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBox Style="{x:Null}"
                                                 Text="{Binding SourceText, Mode=OneWay}" 
                                                 IsReadOnly="True" BorderThickness="0" Background="Transparent" 
                                                 Foreground="White" FontSize="15" FontWeight="Bold" TextWrapping="Wrap"
                                                 SelectionBrush="#99C9EF" SelectionTextBrush="Black"
                                                 VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="5,0,0,0">

                                            <ui:Button Padding="4"
                                                       Opacity="1"
                                                       Appearance="Transparent" 
                                                       Foreground="White"
                                                       Icon="{ui:SymbolIcon Copy24, Filled=False}" 
                                                       Click="CopySourceText_Click" 
                                                       ToolTip="Copy Source Text"
                                                       Margin="0,0,0,5"/>

                                            <ui:Button Padding="4"
                                                       Opacity="1"
                                                       Appearance="Transparent" 
                                                       Foreground="White"
                                                       Icon="{ui:SymbolIcon Sparkle24, Filled=False}" 
                                                       Click="OllamaAction_Click" 
                                                       ToolTip="Send to Ollama AI"/>

                                        </StackPanel>
                                    </Grid>

                                    <TextBox Style="{x:Null}"
                                             Text="{Binding TranslatedText, Mode=OneWay}" 
                                             IsReadOnly="True" BorderThickness="0" Background="Transparent" 
                                             Foreground="#E0E0E0" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"
                                             SelectionBrush="#99C9EF" SelectionTextBrush="Black"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Thumb x:Name="TopThumb" Height="10" VerticalAlignment="Top" Cursor="SizeNS" DragDelta="Thumb_OnDragDelta" Style="{StaticResource TransparentThumbStyle}" />
        <Thumb x:Name="BottomThumb" Height="10" VerticalAlignment="Bottom" Cursor="SizeNS" DragDelta="Thumb_OnDragDelta" Style="{StaticResource TransparentThumbStyle}" />
        <Thumb x:Name="LeftThumb" Width="10" HorizontalAlignment="Left" Cursor="SizeWE" DragDelta="Thumb_OnDragDelta" Style="{StaticResource TransparentThumbStyle}" />
        <Thumb x:Name="RightThumb" Width="10" HorizontalAlignment="Right" Cursor="SizeWE" DragDelta="Thumb_OnDragDelta" Style="{StaticResource TransparentThumbStyle}" />
        <Thumb x:Name="TopLeftThumb" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE" DragDelta="Thumb_OnDragDelta" Style="{StaticResource TransparentThumbStyle}" />
        <Thumb x:Name="TopRightThumb" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" DragDelta="Thumb_OnDragDelta" Style="{StaticResource TransparentThumbStyle}" />
        <Thumb x:Name="BottomLeftThumb" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" DragDelta="Thumb_OnDragDelta" Style="{StaticResource TransparentThumbStyle}" />
        <Thumb x:Name="BottomRightThumb" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" DragDelta="Thumb_OnDragDelta" Style="{StaticResource TransparentThumbStyle}" />
    </Grid>
</Window>