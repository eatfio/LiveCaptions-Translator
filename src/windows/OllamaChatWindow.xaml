<Window
    x:Class="LiveCaptionsTranslator.OllamaChatWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Anki制卡助手" Height="600" Width="550"
    WindowStartupLocation="CenterScreen"
    Background="#202020">

	<Grid Margin="15">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<Border Grid.Row="0" Background="#333333" CornerRadius="5" Padding="10" Margin="0,0,0,15">
			<StackPanel>
				<TextBlock Text="外语原文：" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,5"/>
				<TextBox x:Name="SourceTextBox" Style="{x:Null}" AcceptsReturn="True" TextWrapping="Wrap" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="14"/>
			</StackPanel>
		</Border>

		<Border Grid.Row="1" Background="#333333" CornerRadius="5" Padding="10" Margin="0,0,0,15">
			<StackPanel>
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<TextBlock Text="模型名称：" Foreground="#AAAAAA" VerticalAlignment="Center"/>

					<TextBox x:Name="ModelTextBox" Style="{x:Null}" Grid.Column="1" Margin="10,0" Padding="2" Background="#2B2B2B" Foreground="White" BorderThickness="1" BorderBrush="#555"/>

					<ui:Button x:Name="GenerateBtn" Grid.Column="2" Content="发送 / 重新生成" Click="GenerateBtn_Click" Appearance="Primary" Foreground="White"/>
				</Grid>

				<TextBlock Text="自定义 Prompt (要求 AI 按 正面：和 反面：输出)：" Foreground="#AAAAAA" FontSize="12" Margin="0,10,0,5"/>

				<TextBox x:Name="PromptTextBox" Style="{x:Null}" AcceptsReturn="True" TextWrapping="Wrap" Height="70" VerticalScrollBarVisibility="Auto" Background="#2B2B2B" Foreground="White" BorderThickness="1" BorderBrush="#555" Padding="5" />
			</StackPanel>
		</Border>

		<Border Grid.Row="2" Background="#2B2B2B" CornerRadius="5" Padding="10" Margin="0,0,0,15">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>
				<TextBlock Grid.Row="0" Text="Ollama 实时回复 (选中文本后点击鼠标中键可替换为 _)：" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,5"/>
				<TextBox x:Name="ResponseTextBox" Style="{x:Null}" AcceptsReturn="True" Grid.Row="1" IsReadOnly="False" TextWrapping="Wrap" Background="Transparent" Foreground="#E0E0E0" BorderThickness="0" FontSize="14" VerticalScrollBarVisibility="Auto"
                         PreviewMouseDown="ResponseTextBox_PreviewMouseDown"/>
			</Grid>
		</Border>

		<Border Grid.Row="3" Background="#333333" CornerRadius="5" Padding="10">
			<Grid>
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<TextBlock Grid.Column="0" Text="发音：" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,5,0"/>
				<ComboBox x:Name="LangComboBox" Grid.Column="1" SelectedIndex="3" VerticalAlignment="Center" Background="#2B2B2B" Foreground="White" Margin="0,0,15,0">
					<ComboBoxItem Content="英语" Tag="en"/>
					<ComboBoxItem Content="法语" Tag="fr"/>
					<ComboBoxItem Content="西班牙语" Tag="es"/>
					<ComboBoxItem Content="意大利语" Tag="it"/>
					<ComboBoxItem Content="德语" Tag="de"/>
				</ComboBox>

				<TextBlock Grid.Column="2" Text="牌型：" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,5,0"/>
				<ComboBox x:Name="CardTypeComboBox" Grid.Column="3" SelectedIndex="1" VerticalAlignment="Center" Background="#2B2B2B" Foreground="White">
					<ComboBoxItem Content="Basic"/>
					<ComboBoxItem Content="Basic (and reversed card)"/>
				</ComboBox>

				<ui:Button x:Name="AnkiBtn" Grid.Column="4" Margin="10,0,0,0" Content="一键传给 Anki" Appearance="Success" Foreground="White" Click="AnkiBtn_Click" ToolTip="请确保后台已打开 Anki 并且安装了 AnkiConnect 插件"/>
			</Grid>
		</Border>
	</Grid>
</Window>